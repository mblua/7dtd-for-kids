<configs>

  <!-- ============================================================ -->
  <!-- 7 Days For Kids — Gore Block Replacement                     -->
  <!-- CANNOT <remove> blocks that are parents via Extends.          -->
  <!-- Instead: make decorative gore invisible, replace loot         -->
  <!-- containers with clean models.                                -->
  <!-- Shape="Invisible" makes the block not render (like air)       -->
  <!-- while keeping the block definition alive for Extends chains.  -->
  <!-- ============================================================ -->

  <!-- ======== GORE BLOCKS — Make invisible (decorative, no loot) ======== -->

  <!-- goreBlockAnimal: standalone, no children -->
  <set xpath="/blocks/block[@name='goreBlockAnimal']/property[@name='Shape']/@value">Invisible</set>

  <!-- goreBlockHumanCorpse: PARENT of Corpse1/2/3 -->
  <set xpath="/blocks/block[@name='goreBlockHumanCorpse']/property[@name='Shape']/@value">Invisible</set>
  <!-- Children override Shape via Extends — set each that has own Shape or inherits ModelEntity -->
  <set xpath="/blocks/block[@name='goreBlockHumanCorpse1']/property[@name='Model']/@value"></set>
  <set xpath="/blocks/block[@name='goreBlockHumanCorpse2']/property[@name='Model']/@value"></set>
  <set xpath="/blocks/block[@name='goreBlockHumanCorpse3']/property[@name='Model']/@value"></set>

  <!-- goreBlockHumanBones: PARENT of goreHumanSkull -->
  <set xpath="/blocks/block[@name='goreBlockHumanBones']/property[@name='Shape']/@value">Invisible</set>

  <!-- ======== HANGING CORPSES — Make invisible ======== -->
  <!-- White parents define Shape+Model. Children inherit. -->

  <set xpath="/blocks/block[@name='corpseHangingLog1White']/property[@name='Shape']/@value">Invisible</set>
  <set xpath="/blocks/block[@name='corpseHangingLog2White']/property[@name='Shape']/@value">Invisible</set>
  <set xpath="/blocks/block[@name='corpseHangingLog3White']/property[@name='Shape']/@value">Invisible</set>
  <set xpath="/blocks/block[@name='corpseHangingRope1White']/property[@name='Shape']/@value">Invisible</set>

  <!-- ======== GORE BATHTUB — LOOT CONTAINER (keep loot, clean model) ======== -->
  <!-- cntBathTubGore is PARENT of cntBathTubsRandomLootHelper. -->

  <set xpath="/blocks/block[@name='cntBathTubGore']/property[@name='Model']/@value">@:Entities/LootContainers/bathTubEmptyPrefab.prefab</set>
  <remove xpath="/blocks/block[@name='cntBathTubGore']/property[@name='Censor']"/>
  <set xpath="/blocks/block[@name='cntBathTubGore']/property[@name='DowngradeFX']/@value">organicdestroy3</set>

</configs>
