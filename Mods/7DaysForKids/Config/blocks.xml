<configs>

  <!-- ============================================================ -->
  <!-- 7 Days For Kids — Gore Block Replacement                     -->
  <!-- Replace gore models with rubble/debris. Cannot <remove>       -->
  <!-- blocks that are Extends parents — children would crash.      -->
  <!-- ============================================================ -->

  <!-- ======== GORE BLOCKS — Replace with rubble pile ======== -->

  <!-- goreBlockAnimal: standalone, no children -->
  <set xpath="/blocks/block[@name='goreBlockAnimal']/property[@name='Model']/@value">@:Entities/Debris/rubblePileBricksPrefab.prefab</set>

  <!-- goreBlockHumanCorpse: PARENT of Corpse1/2/3 (children override Model) -->
  <set xpath="/blocks/block[@name='goreBlockHumanCorpse']/property[@name='Model']/@value">@:Entities/Debris/rubblePileBricksPrefab.prefab</set>
  <set xpath="/blocks/block[@name='goreBlockHumanCorpse1']/property[@name='Model']/@value">@:Entities/Debris/rubblePileBricksPrefab.prefab</set>
  <set xpath="/blocks/block[@name='goreBlockHumanCorpse2']/property[@name='Model']/@value">@:Entities/Debris/rubblePileBricksPrefab.prefab</set>
  <!-- goreBlockHumanCorpse2Offset inherits from Corpse2 — no set needed -->
  <set xpath="/blocks/block[@name='goreBlockHumanCorpse3']/property[@name='Model']/@value">@:Entities/Debris/rubblePileBricksPrefab.prefab</set>

  <!-- goreBlockHumanBones: PARENT of goreHumanSkull -->
  <set xpath="/blocks/block[@name='goreBlockHumanBones']/property[@name='Model']/@value">@:Entities/Debris/rubblePileBricksPrefab.prefab</set>
  <set xpath="/blocks/block[@name='goreHumanSkull']/property[@name='Model']/@value">@:Entities/Debris/rubblePileBricksPrefab.prefab</set>

  <!-- ======== HANGING CORPSES — Replace with rubbish decal ======== -->
  <!-- White parents define Model. Color children inherit from parent. -->

  <set xpath="/blocks/block[@name='corpseHangingLog1White']/property[@name='Model']/@value">@:Entities/Debris/groundDecalRubbish01Prefab.prefab</set>
  <set xpath="/blocks/block[@name='corpseHangingLog2White']/property[@name='Model']/@value">@:Entities/Debris/groundDecalRubbish01Prefab.prefab</set>
  <set xpath="/blocks/block[@name='corpseHangingLog3White']/property[@name='Model']/@value">@:Entities/Debris/groundDecalRubbish01Prefab.prefab</set>
  <set xpath="/blocks/block[@name='corpseHangingRope1White']/property[@name='Model']/@value">@:Entities/Debris/groundDecalRubbish01Prefab.prefab</set>

  <!-- ======== GORE BATHTUB — LOOT CONTAINER (keep loot, clean model) ======== -->
  <!-- cntBathTubGore is PARENT of cntBathTubsRandomLootHelper. -->

  <set xpath="/blocks/block[@name='cntBathTubGore']/property[@name='Model']/@value">@:Entities/LootContainers/bathTubEmptyPrefab.prefab</set>
  <remove xpath="/blocks/block[@name='cntBathTubGore']/property[@name='Censor']"/>
  <set xpath="/blocks/block[@name='cntBathTubGore']/property[@name='DowngradeFX']/@value">organicdestroy3</set>

</configs>
